# Copy to .env — never commit .env or paste these into chat/AI tools.
# GoDaddy API: https://developer.godaddy.com/keys
#
# Use a Production key for real DNS (urbanhilt.com). OTE/Test keys only work with:
#   GODADDY_API_HOST=api.ote-godaddy.com
# and are not for your live domain.

GODADDY_KEY=
GODADDY_SECRET=
GODADDY_DOMAIN=urbanhilt.com

# Railway: add custom domain in dashboard first, then use the CNAME target shown:
# RAILWAY_WWW_TARGET=xxxx.up.railway.app

# Railway CLI scripts: token + project id only (environment & service auto-detected)
# https://railway.com/account/tokens — never commit a real token
# RAILWAY_TOKEN=
# RAILWAY_PROJECT_ID=          # Cmd/Ctrl+K → Copy project ID
# Optional overrides: RAILWAY_ENVIRONMENT_ID=  RAILWAY_SERVICE_ID=

# Client production URL (set on the CLIENT Railway service — the deploy with www.urbanhilt.com)
# PUBLIC_SITE_URL=https://www.urbanhilt.com

# --- Urban Hilt store (Railway / production) ---
# Strong secrets in production; never commit real .env
JWT_SECRET=
STAFF_JWT_SECRET=
# Optional; customer session JWT (defaults if unset)
# CUSTOMER_SECRET=

# When true: customers POST orders as "awaiting_staff" (no stock yet); staff confirms via Admin or POS
REQUIRE_STAFF_CHECKOUT=true

# When true, shoppers are sent to /staff-access.html until a rep signs in (optional)
STAFF_GATE_FULL_SITE=false

# Paystack payment gateway (public key is exposed to the browser via /api/store-config)
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
